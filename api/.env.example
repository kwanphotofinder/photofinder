# Database Configuration (Neon or local PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/facesearch?schema=public"

# Weaviate Vector Database
WEAVIATE_HOST="localhost:8080"
WEAVIATE_SCHEME="http"

# AI Face Processing Service
AI_SERVICE_URL="http://localhost:8000"

# Storage Configuration (Choose ONE block below)

# --- Option A: Cloudinary ---
STORAGE_PROVIDER="cloudinary"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_FOLDER="photos"

# --- Option B: MinIO ---
# STORAGE_PROVIDER="minio"
# MINIO_ENDPOINT="localhost"
# MINIO_PORT=9000
# MINIO_ACCESS_KEY="minioadmin"
# MINIO_SECRET_KEY="minioadmin"
# MINIO_BUCKET="photos"
# MINIO_USE_SSL="false"

# Application Security
PORT=3000
JWT_SECRET="super-secret-key-change-me"

# Google Authentication
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# IMPORTANT: Copy this file to .env and update the values
# For production (Render), use strong passwords and put these directly into Render Environment Variables!
